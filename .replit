modules = ["web", "python-base-3.13", "nodejs-22"]
run = "source /home/runner/cacao-accounting/venv/bin/activate && CACAO_TEST=True SECRET_KEY=abcABC123 /home/runner/cacao-accounting/venv/bin/flask run --reload --debug"

[nix]
channel = "stable-24_05"

[deployment]
run = [
    "sh",
    "-c",
    "source /home/runner/cacao-accounting/venv/bin/activate && CACAO_TEST=True SECRET_KEY=abcABC123 /home/runner/cacao-accounting/venv/bin/flask run --reload --debug",
]

[[ports]]
localPort = 5000
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8080
externalPort = 8080

[rules]

[rules.formatter]

[rules.formatter.fileExtensions]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CACAO_TEST=True SECRET_KEY=abcABC123 CACAO_DATABASE_URL=sqlite:////tmp/cacao_app.db /tmp/app_venv/bin/flask run --port 5000"
waitForPort = 5000
