+{% extends "base.html" %}
+{% block contenido %}
+<nav aria-label="breadcrumb">
+  <ol class="breadcrumb lh-sm">
+    <li class="breadcrumb-item"><a href="{{ url_for('cacao_app.pagina_inicio') }}" class="link-dark">{{ _("Inicio") }}</a></li>
+    <li class="breadcrumb-item"><a href="{{ url_for('contabilidad.conta') }}" class="link-dark">{{ _("Contabilidad") }}</a></li>
+    <li class="breadcrumb-item"><a href="{{ url_for('contabilidad.presupuestos.listar') }}" class="link-dark">{{ _("Presupuestos") }}</a></li>
+    <li class="breadcrumb-item active" aria-current="page">{{ budget.budget_code }}</li>
+  </ol>
+</nav>
+
+<div class="ca-page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
+  <div>
+    <h4><i class="bi bi-wallet2 me-2"></i>{{ budget.name }}</h4>
+    <small class="text-muted">{{ budget.budget_code }} | {{ budget.company }} | {{ budget.fiscal_year_id }}</small>
+  </div>
+  <div class="d-flex gap-2">
+    {% if budget.status == 'draft' %}
+      {% if permisos.editar %}
+      <a href="{{ url_for('contabilidad.presupuestos.editar', budget_id=budget.id) }}" class="btn btn-outline-secondary">
+        <i class="bi bi-pencil"></i> {{ _("Editar Encabezado") }}
+      </a>
+      {% endif %}
+      {% if permisos.importar %}
+      <a href="{{ url_for('contabilidad.presupuestos.importar', budget_id=budget.id) }}" class="btn btn-outline-success">
+        <i class="bi bi-file-earmark-spreadsheet"></i> {{ _("Importar Líneas") }}
+      </a>
+      {% endif %}
+      {% if permisos.autorizar %}
+      <form action="{{ url_for('contabilidad.presupuestos.aprobar', budget_id=budget.id) }}" method="post" onsubmit="return confirm('{{ _('¿Seguro que desea aprobar este presupuesto? Ya no podrá editar líneas.') }}');">
+        <button type="submit" class="btn btn-primary">
+          <i class="bi bi-check-circle"></i> {{ _("Aprobar") }}
+        </button>
+      </form>
+      {% endif %}
+    {% elif budget.status == 'approved' %}
+      {% if permisos.cerrar %}
+      <form action="{{ url_for('contabilidad.presupuestos.cerrar', budget_id=budget.id) }}" method="post" onsubmit="return confirm('{{ _('¿Seguro que desea cerrar este presupuesto?') }}');">
+        <button type="submit" class="btn btn-outline-info">
+          <i class="bi bi-lock"></i> {{ _("Cerrar") }}
+        </button>
+      </form>
+      {% endif %}
+      {% if permisos.reportes %}
+      <a href="{{ url_for('contabilidad.presupuestos.reporte', budget_id=budget.id, company=budget.company, fiscal_year_id=budget.fiscal_year_id, ledger_id=budget.ledger_id) }}" class="btn btn-primary">
+        <i class="bi bi-bar-chart-fill"></i> {{ _("Real vs Presupuesto") }}
+      </a>
+      {% endif %}
+    {% endif %}
+  </div>
+</div>
+
+<div class="row mt-3">
+  <div class="col-lg-3">
+    <div class="ca-card p-3">
+      <h6>{{ _("Detalles") }}</h6>
+      <hr class="my-2">
+      <p class="mb-1"><small><strong>{{ _("Estado") }}:</strong></small><br>
+        <span class="badge bg-{{ 'secondary' if budget.status == 'draft' else 'success' if budget.status == 'approved' else 'info' }}">
+          {{ _("Borrador") if budget.status == "draft" else _("Aprobado") if budget.status == "approved" else _("Cerrado") }}
+        </span>
+      </p>
+      <p class="mb-1"><small><strong>{{ _("Libro") }}:</strong></small><br>{{ budget.ledger_id }}</p>
+      <p class="mb-1"><small><strong>{{ _("Moneda") }}:</strong></small><br>{{ budget.currency_id }}</p>
