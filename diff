+        <a href="{{ url_for('contabilidad.presupuestos.nueva_linea', budget_id=budget.id) }}" class="btn btn-sm btn-primary">
+          <i class="bi bi-plus-lg"></i> {{ _("Agregar Línea") }}
+        </a>
+        {% endif %}
+      </div>
+      <div class="table-responsive">
+        <table class="ca-table">
+          <thead>
+            <tr>
+              <th>{{ _("Cuenta") }}</th>
+              <th>{{ _("Centro de Costo") }}</th>
+              <th>{{ _("Dimensiones") }}</th>
+              <th>{{ _("Período") }}</th>
+              <th class="text-end">{{ _("Monto") }}</th>
+              {% if budget.status == 'draft' %}
+              <th>{{ _("Acciones") }}</th>
+              {% endif %}
+            </tr>
+          </thead>
+          <tbody>
+            {% for line, acc, cc, per, unit, project in lines %}
+            <tr>
+              <td>{{ acc.code }} - {{ acc.name }}</td>
+              <td>{{ cc.code }} - {{ cc.name }}</td>
+              <td>
+                {% if unit %}<span class="badge bg-light text-dark"><i class="bi bi-building"></i> {{ unit.name }}</span>{% endif %}
+                {% if project %}<span class="badge bg-light text-dark"><i class="bi bi-diagram-3"></i> {{ project.name }}</span>{% endif %}
+              </td>
+              <td>{{ per.name }}</td>
+              <td class="text-end">{{ line.amount|format_currency }}</td>
+              {% if budget.status == 'draft' %}
+              <td>
+                <div class="btn-group btn-group-sm">
+                  {% if permisos.editar %}
+                  <a href="{{ url_for('contabilidad.presupuestos.editar_linea', line_id=line.id) }}" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i></a>
+                  {% endif %}
+                  {% if permisos.eliminar %}
+                  <form action="{{ url_for('contabilidad.presupuestos.eliminar_linea', line_id=line.id) }}" method="post" style="display:inline;" onsubmit="return confirm('{{ _('¿Eliminar línea?') }}');">
+                    <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
+                  </form>
+                  {% endif %}
+                </div>
+              </td>
+              {% endif %}
+            </tr>
+            {% else %}
+            <tr>
+              <td colspan="5" class="text-center">{{ _("No hay líneas registradas.") }}</td>
+            </tr>
+            {% endfor %}
+          </tbody>
+        </table>
+      </div>
+    </div>
+  </div>
