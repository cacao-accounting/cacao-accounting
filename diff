+        return redirect(url_for("contabilidad.presupuestos.listar"))
+
+    form = FormularioBudget(obj=budget)
+    form.company.choices = obtener_lista_entidades_por_id_razonsocial()
+    form.currency_id.choices = obtener_lista_monedas()
+
