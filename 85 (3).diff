+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: 2025 - 2026 William José Moreno Reyes
+
+"""Accounting Mapper implementation."""
+
+from __future__ import annotations
+from decimal import Decimal
+from typing import List, Optional
+from cacao_accounting.accounting_engine.common.context import (
+    CalculationContext,
+    FiscalResult,
+    LandedCostResult,
+    SettlementResult,
+    JournalEntryProforma,
+    JournalEntryLineProforma,
+)
+
+
+class AccountingMapper:
+    """Maps economic results from engines to pro-forma journal entries."""
+
+    def map_to_proforma(
+        self,
+        context: CalculationContext,
+        fiscal: Optional[FiscalResult] = None,
+        landed: Optional[LandedCostResult] = None,
+        settlement: Optional[SettlementResult] = None,
+    ) -> JournalEntryProforma:
+        """Create a pro-forma journal entry from engine results."""
+        lines: List[JournalEntryLineProforma] = []
+        direction = context.transaction_direction
+
+        # 1. Map Fiscal Lines
+        if fiscal:
+            for line in fiscal.tax_lines:
+                if not line.affects_document_total:
+                    continue
+
+                account_id = line.account_id or context.references.get(f"default_{line.concept}_account")
+                if not account_id:
+                    continue
+
+                # Purchases: Tax usually Debited (reclaimable) or Credited (withholding)
+                # Sales: Tax usually Credited (payable) or Debited (withholding)
+                is_debit = (direction == "purchase" and line.type != "withholding") or \
+                           (direction == "sales" and line.type == "withholding")
+
+                amount = line.amount
+                lines.append(
+                    JournalEntryLineProforma(
+                        account_id=account_id,
+                        debit=amount if is_debit else Decimal("0"),
+                        credit=Decimal("0") if is_debit else amount,
+                        description=f"{line.concept} - {context.document_type}",
+                        party_id=context.party_id if line.type == "withholding" else None
+                    )
+                )
+
+        # 2. Map Goods / Inventory
+        total_goods = sum((item.net_amount for item in context.items), Decimal("0"))
+        if total_goods > 0:
+            goods_account = context.references.get("goods_account")
+            if goods_account:
+                is_debit = direction == "purchase"
+                lines.append(
+                    JournalEntryLineProforma(
+                        account_id=goods_account,
+                        debit=total_goods if is_debit else Decimal("0"),
+                        credit=Decimal("0") if is_debit else total_goods,
+                        description=f"Base Goods - {context.document_type}"
+                    )
+                )
+
+        # 3. Map Settlement / AR / AP
+        if settlement:
+            total_payable = settlement.gross_settlement_amount
+            party_account = context.references.get("party_account")
+            if party_account and total_payable > 0:
+                is_debit = direction == "sales"  # AR
+                lines.append(
+                    JournalEntryLineProforma(
+                        account_id=party_account,
+                        debit=total_payable if is_debit else Decimal("0"),
+                        credit=Decimal("0") if is_debit else total_payable,
+                        description=f"Party Balance - {context.document_type}",
+                        party_id=context.party_id
+                    )
+                )
+
+        # 4. Final Balancing
+        # If there is a rounding difference, adjust the largest line or party account
+        proforma = JournalEntryProforma(lines=lines, memo=f"Pro-forma for {context.document_type}")
+        if not proforma.is_balanced and lines:
+            debits = sum((line_item.debit for line_item in lines), Decimal("0"))
+            credits = sum((line_item.credit for line_item in lines), Decimal("0"))
+            diff = debits - credits
+
+            # Find a line to adjust (prefer party account or goods account)
+            adjustment_line: Optional[JournalEntryLineProforma] = None
+            for line_item in lines:
+                if line_item.account_id in (
+                    context.references.get("party_account"),
+                    context.references.get("goods_account"),
+                ):
+                    adjustment_line = line_item
+                    break
+
+            if not adjustment_line:
+                adjustment_line = lines[0]
+
+            # Create a new adjusted line (since dataclass is frozen)
+            idx = lines.index(adjustment_line)
+            if adjustment_line.debit > 0:
+                new_line = JournalEntryLineProforma(
+                    account_id=adjustment_line.account_id,
+                    debit=adjustment_line.debit - diff,
+                    credit=adjustment_line.credit,
+                    description=adjustment_line.description,
+                    party_id=adjustment_line.party_id,
+                )
+            else:
+                new_line = JournalEntryLineProforma(
+                    account_id=adjustment_line.account_id,
+                    debit=adjustment_line.debit,
+                    credit=adjustment_line.credit + diff,
+                    description=adjustment_line.description,
+                    party_id=adjustment_line.party_id,
+                )
+            lines[idx] = new_line
+
+        return JournalEntryProforma(lines=lines, memo=f"Pro-forma for {context.document_type}")
